{
  "name": "godhotline",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"ts-node -r ./register.js src/server.ts\"",
    "dev:client": "npm run dev --prefix client",
    "build": "tsc",
    "build:client": "npm run build --prefix client",
    "build:all": "npm run build && npm run build:client",
    "start": "node -r ./register.js dist/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "AI-powered community resource hotline via Twilio voice + SMS",
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "axios": "^1.18.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "openai": "^6.43.0",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
